# Copy to worker.env (same folder) and fill in. worker.env is gitignored.
#
# Local mode: leave KANBAN_API_URL/KANBAN_API_TOKEN blank. The worker edits this
# checkout's board.json directly.
#
# Remote/Docker mode: set both values so the worker talks to the board API.
# KANBAN_API_URL=https://kanban.chattoweb.com
# KANBAN_API_TOKEN=lk_replace_with_a_real_token

# Optional:
# KANBAN_AI_PROVIDER=auto
# KANBAN_AI_BIN=/Applications/Codex.app/Contents/Resources/codex
# KANBAN_AI_ARGS=
# KANBAN_WORKER_MAX=3
# KANBAN_WORKER_RESULTS=/var/lib/kanban-worker/results
# KANBAN_WORKER_SET_RESULT=1
