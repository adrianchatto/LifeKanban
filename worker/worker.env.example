# Copy to worker.env (same folder) and fill in. worker.env is gitignored.
# Required:
KANBAN_API_URL=https://kanban.chattoweb.com
KANBAN_API_TOKEN=lk_replace_with_a_real_token

# Optional:
# CLAUDE_BIN=claude
# KANBAN_CLAUDE_ARGS=--model claude-sonnet-4-6
# KANBAN_WORKER_MAX=3
# KANBAN_WORKER_RESULTS=/var/lib/kanban-worker/results
