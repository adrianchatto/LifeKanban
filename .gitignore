# Runtime / state — not part of the app
.notify-state.json
.notify.log
.server.log
.board.lock
*.tmp
.board.*.tmp
.sync-result.txt
.install-skill-result.txt
.start-result.txt

# Card attachments / screenshots — kept local, not synced to GitHub
attachments/

# Accounts & secrets — NEVER commit these (password hashes, encrypted API keys,
# the master encryption key). Losing .secret.key means stored API keys can no
# longer be decrypted and users must re-enter them.
users.json
.secret.key
.users.lock

# Per-user data (other people's boards, results, attachments) stays local
boards/
results/u-*/
attachments/u-*/

# macOS
.DS_Store

# Python bytecode
__pycache__/
*.pyc
